# Copy this file to secrets.yaml and fill in your own values.
# secrets.yaml is excluded from version control (.gitignore).
#
# Reference values in other config files with: !secret <key>
# Example:  password: !secret my_password

# --- General ---
# http_password: change_me

# --- MQTT ---
# mqtt_broker: 192.168.1.x
# mqtt_username: homeassistant
# mqtt_password: change_me

# --- Notification services ---
# pushover_user_key: xxxxxxxxxxxxxxxxxxxx
# pushover_api_token: xxxxxxxxxxxxxxxxxxxx

# --- External access ---
# external_url: https://your-domain.duckdns.org
# internal_url: http://homeassistant.local:8123
